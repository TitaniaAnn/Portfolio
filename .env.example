# Portfolio environment configuration template.
# Copy this to `.env` (at the project root) and fill in real values.
# `.env` is gitignored; this `.env.example` is committed as documentation.

# ── Database ────────────────────────────────────────────────
DB_HOST=localhost
DB_NAME=
DB_USER=
DB_PASS=
DB_CHARSET=utf8mb4

# ── App ─────────────────────────────────────────────────────
APP_URL=https://your-domain.com
# Generate with: openssl rand -hex 32
APP_SECRET=

# ── Session ─────────────────────────────────────────────────
# Lifetime in seconds (28800 = 8 hours)
SESSION_LIFETIME=28800

# ── Whitelisted admin emails (comma-separated) ──────────────
# Only these accounts can sign in to the admin panel.
ADMIN_EMAILS=you@example.com

# ── Google OAuth ────────────────────────────────────────────
# Console: https://console.cloud.google.com/apis/credentials
# Authorised redirect URI: APP_URL + /api/auth/google/callback.php
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── GitHub OAuth ────────────────────────────────────────────
# Console: https://github.com/settings/developers
# Callback URL: APP_URL + /api/auth/github/callback.php
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
